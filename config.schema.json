{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "type": "object",
  "properties": {
    "$schema": {
      "description": "JSON Schema reference; ignored at runtime.",
      "type": [
        "string",
        "null"
      ],
      "default": null
    },
    "http": {
      "description": "HTTP transport settings; only used with `--transport http`.",
      "$ref": "#/$defs/HttpConfig"
    },
    "query_timeout_seconds": {
      "description": "Per-query timeout in seconds. Default 30.",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0
    },
    "sources": {
      "description": "Named data sources. The map key is the `source` argument MCP clients\npass on every tool call.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/SourceConfig"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "HttpConfig": {
      "type": "object",
      "properties": {
        "addr": {
          "description": "Listen address. Default 127.0.0.1:7100.",
          "type": "string",
          "default": "127.0.0.1:7100"
        },
        "path": {
          "description": "Path the MCP endpoint is mounted at. Default /mcp.",
          "type": "string",
          "default": "/mcp"
        },
        "stateless": {
          "description": "Run without server-side sessions (no server->client requests, so\nper-workspace roots configs do not work in this mode).",
          "type": "boolean",
          "default": false
        },
        "json_response": {
          "description": "Return plain JSON responses instead of SSE streams (stateless only).",
          "type": "boolean",
          "default": false
        },
        "allowed_origins": {
          "description": "Extra Origin/Host values to accept besides localhost. `[\"*\"]` disables\nthe check entirely (put a trusted proxy in front).",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "SourceConfig": {
      "type": "object",
      "properties": {
        "engine": {
          "description": "Database engine.",
          "$ref": "#/$defs/EngineKind"
        },
        "description": {
          "description": "Free-text description surfaced via list_sources so a model can pick\nthe right source unaided.",
          "type": [
            "string",
            "null"
          ]
        },
        "readonly": {
          "description": "Refuse all write tools on this source.",
          "type": "boolean",
          "default": false
        },
        "dsn": {
          "description": "Full connection string (engine-native format). Mutually exclusive\nwith host/port/user/password/database. `uri` is accepted as an alias.",
          "type": [
            "string",
            "null"
          ]
        },
        "host": {
          "type": [
            "string",
            "null"
          ]
        },
        "port": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "minimum": 0,
          "maximum": 65535
        },
        "user": {
          "type": [
            "string",
            "null"
          ]
        },
        "password": {
          "description": "Password. Supports `${ENV_VAR}` expansion.",
          "type": [
            "string",
            "null"
          ]
        },
        "database": {
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "description": "Database file path (sqlite/duckdb only). Supports `~` expansion.",
          "type": [
            "string",
            "null"
          ]
        },
        "default_database": {
          "description": "Default database for document tools (mongodb only).",
          "type": [
            "string",
            "null"
          ]
        },
        "connect_timeout_seconds": {
          "description": "Connect timeout in seconds. Default 10.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "ssh": {
          "description": "SSH tunnel: the database is dialed through this host.",
          "anyOf": [
            {
              "$ref": "#/$defs/SshConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "docker": {
          "description": "Docker container the database runs in: the published port (or the\ncontainer IP) is dialed instead of host/port.",
          "anyOf": [
            {
              "$ref": "#/$defs/DockerConfig"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "engine"
      ]
    },
    "EngineKind": {
      "type": "string",
      "enum": [
        "mysql",
        "mariadb",
        "postgres",
        "sqlite",
        "duckdb",
        "mssql",
        "clickhouse",
        "redis",
        "mongodb"
      ]
    },
    "SshConfig": {
      "type": "object",
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "description": "Default 22.",
          "type": "integer",
          "format": "uint16",
          "minimum": 0,
          "maximum": 65535,
          "default": 22
        },
        "user": {
          "type": "string"
        },
        "password": {
          "description": "Password auth. Supports `${ENV_VAR}` expansion.",
          "type": [
            "string",
            "null"
          ]
        },
        "identity_file": {
          "description": "Private key file. Supports `~` expansion.",
          "type": [
            "string",
            "null"
          ]
        },
        "passphrase": {
          "description": "Passphrase for the private key. Supports `${ENV_VAR}` expansion.",
          "type": [
            "string",
            "null"
          ]
        },
        "use_agent": {
          "description": "Use the running ssh-agent (SSH_AUTH_SOCK). With no identity_file,\npassword or use_agent configured, the agent and then ~/.ssh default\nkeys are tried automatically.",
          "type": "boolean",
          "default": false
        },
        "known_hosts_file": {
          "description": "known_hosts file used for host-key verification. Default ~/.ssh/known_hosts.",
          "type": [
            "string",
            "null"
          ]
        },
        "insecure_ignore_host_key": {
          "description": "Skip host-key verification. Do not use outside throwaway environments.",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false,
      "required": [
        "host",
        "user"
      ]
    },
    "DockerConfig": {
      "type": "object",
      "properties": {
        "container": {
          "description": "Container name or id.",
          "type": "string"
        },
        "port": {
          "description": "Port inside the container; defaults to the engine's default port.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "minimum": 0,
          "maximum": 65535
        }
      },
      "additionalProperties": false,
      "required": [
        "container"
      ]
    }
  }
}
